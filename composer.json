{
	"name": "rdcstarr/laravel-locale",
	"description": "Database-driven language, country and translation management for Laravel.",
	"type": "library",
	"keywords": [
		"laravel",
		"locale",
		"language",
		"country",
		"translation",
		"i18n",
		"l10n",
		"database-translations",
		"octane"
	],
	"homepage": "https://github.com/rdcstarr/laravel-locale",
	"license": "MIT",
	"authors": [
		{
			"name": "Rdcstarr",
			"email": "rdcstarr@gmail.com",
			"role": "Developer"
		}
	],
	"require": {
		"php": "^8.3",
		"laravel/framework": "^12.0",
		"spatie/laravel-package-tools": "^1.16",
		"illuminate/contracts": "^11.0||^12.0"
	},
	"require-dev": {
		"orchestra/testbench": "^10.0",
		"phpunit/phpunit": "^11.0"
	},
	"autoload": {
		"psr-4": {
			"Rdcstarr\\Locale\\": "src/",
			"Rdcstarr\\Locale\\Database\\Seeders\\": "database/seeders/"
		},
		"files": [
			"src/helpers.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Rdcstarr\\Locale\\Tests\\": "tests/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"Rdcstarr\\Locale\\LocaleServiceProvider"
			],
			"aliases": {
				"Locale": "Rdcstarr\\Locale\\Facades\\Locale",
				"Translate": "Rdcstarr\\Locale\\Facades\\Translate"
			}
		}
	},
	"config": {
		"sort-packages": true
	}
}
